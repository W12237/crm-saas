generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════
// CORE: USERS & AUTH
// ═══════════════════════════════════════

model User {
  id              Int      @id @default(autoincrement())
  name            String
  email           String   @unique
  password        String
  role            String   @default("SALES_EXECUTIVE")
  department      String?
  status          String   @default("ACTIVE")
  organization_id Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // CRM
  leads             Lead[]
  // Phase 2
  tasksAssigned     Task[]          @relation("TaskAssignee")
  tasksCreated      Task[]          @relation("TaskCreator")
  // Finance
  invoicesCreated   Invoice[]       @relation("InvoiceCreator")
  expensesCreated   Expense[]       @relation("ExpenseCreator")
  payrollEntries    Payroll[]
  // New
  projectsCreated   Project[]       @relation("ProjectCreator")
  campaignsCreated  Campaign[]      @relation("CampaignCreator")
  vendorsCreated    Vendor[]        @relation("VendorCreator")
  rfqsCreated       RFQ[]           @relation("RFQCreator")
  purchaseOrders    PurchaseOrder[] @relation("POCreator")
  notifications     Notification[]
  activityLogs      ActivityLog[]   @relation("ActivityUser")
  milestonesCreated Milestone[]     @relation("MilestoneCreator")
  // POS & Inventory
  salesCreated      PosSale[]          @relation("SaleCashier")
  purchasesCreated  StockPurchase[]    @relation("PurchaseCreator")
  deliveriesDriver  Delivery[]         @relation("DeliveryDriver")
  // Marketing OAuth
  marketingAccounts MarketingAccount[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// ROLE CATALOGUE  (DB-driven, synced with RBAC_MATRIX keys)
// User.role (String) stores the `key` value — no FK to keep backward compat.
// Future: add Permission + RolePermission models here for granular ACL.
// ─────────────────────────────────────────────────────────────────────────────

model Role {
  id        Int      @id @default(autoincrement())
  key       String   @unique  // RBAC identifier: SUPER_ADMIN, SALES_MANAGER …
  label     String            // Human display name: "Super Admin", "Sales Manager" …
  createdAt DateTime @default(now())

  @@map("roles")
}

// ═══════════════════════════════════════
// PHASE 1: CRM
// ═══════════════════════════════════════

model Lead {
  id              Int      @id @default(autoincrement())
  name            String
  phone           String?
  email           String?
  source          String?
  stage           String   @default("LEAD")
  deal_value      Decimal?
  probability     Int?     @default(0)
  created_by      Int
  organization_id Int?
  campaign_id     Int?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  creator      User          @relation(fields: [created_by], references: [id])
  campaign     Campaign?     @relation(fields: [campaign_id], references: [id])
  deals        Deal[]
  activityLogs ActivityLog[]

  @@map("leads")
}

model Client {
  id              Int      @id @default(autoincrement())
  name            String
  company         String?
  phone           String?
  whatsapp_phone  String?
  email           String?
  organization_id Int?
  address         String?
  website         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  deals        Deal[]
  projects     Project[]
  invoices     Invoice[]
  campaigns    Campaign[]    @relation("ClientCampaigns")
  activityLogs ActivityLog[]
  posSales     PosSale[]     @relation("ClientPosSales")

  @@map("clients")
}

model Deal {
  id                  Int      @id @default(autoincrement())
  lead_id             Int?
  client_id           Int?
  value               Decimal?
  status              String   @default("ACTIVE")
  expected_close_date DateTime?
  organization_id     Int?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  lead         Lead?         @relation(fields: [lead_id], references: [id])
  client       Client?       @relation(fields: [client_id], references: [id])
  projects     Project[]
  invoices     Invoice[]
  activityLogs ActivityLog[]

  @@map("deals")
}

// ═══════════════════════════════════════
// PHASE 2: OPERATIONS
// ═══════════════════════════════════════

model Project {
  id                  Int      @id @default(autoincrement())
  title               String
  description         String?
  client_id           Int?
  deal_id             Int?
  type                String   @default("ICT")
  status              String   @default("PLANNING")
  budget              Decimal?
  progress_percentage Int      @default(0)
  start_date          DateTime?
  end_date            DateTime?
  organization_id     Int?
  created_by          Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  client       Client?       @relation(fields: [client_id], references: [id])
  deal         Deal?         @relation(fields: [deal_id], references: [id])
  creator      User?         @relation("ProjectCreator", fields: [created_by], references: [id])
  tasks        Task[]
  milestones   Milestone[]
  invoices     Invoice[]
  expenses     Expense[]
  campaigns    Campaign[]    @relation("ProjectCampaigns")
  activityLogs ActivityLog[]

  @@map("projects")
}

model Task {
  id              Int      @id @default(autoincrement())
  title           String
  description     String?
  project_id      Int
  assigned_to     Int?
  created_by      Int
  status          String   @default("TODO")
  priority        String   @default("MEDIUM")
  due_date        DateTime?
  organization_id Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project      Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  assignee     User?         @relation("TaskAssignee", fields: [assigned_to], references: [id])
  creator      User          @relation("TaskCreator", fields: [created_by], references: [id])
  activityLogs ActivityLog[]

  @@map("tasks")
}

model Milestone {
  id              Int      @id @default(autoincrement())
  title           String
  description     String?
  project_id      Int
  status          String   @default("PENDING")
  due_date        DateTime?
  completed_date  DateTime?
  created_by      Int
  organization_id Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  creator User    @relation("MilestoneCreator", fields: [created_by], references: [id])

  @@map("milestones")
}

// ═══════════════════════════════════════
// PHASE 3: FINANCE
// ═══════════════════════════════════════

model Invoice {
  id              Int      @id @default(autoincrement())
  client_id       Int
  project_id      Int?
  deal_id         Int?
  invoice_number  String   @unique
  amount          Decimal
  tax             Decimal  @default(0)
  total_amount    Decimal
  status          String   @default("DRAFT")
  issued_date     DateTime @default(now())
  due_date        DateTime?
  notes           String?
  created_by      Int
  organization_id Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client   Client    @relation(fields: [client_id], references: [id])
  project  Project?  @relation(fields: [project_id], references: [id])
  deal     Deal?     @relation(fields: [deal_id], references: [id])
  creator  User      @relation("InvoiceCreator", fields: [created_by], references: [id])
  payments Payment[]

  @@map("invoices")
}

model Payment {
  id               Int      @id @default(autoincrement())
  invoice_id       Int
  amount_paid      Decimal
  payment_method   String   @default("BANK_TRANSFER")
  payment_date     DateTime @default(now())
  reference_number String?
  notes            String?
  organization_id  Int?
  createdAt        DateTime @default(now())

  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Expense {
  id              Int      @id @default(autoincrement())
  title           String
  category        String   @default("OTHER")
  amount          Decimal
  project_id      Int?
  vendor_id       Int?
  created_by      Int
  date            DateTime @default(now())
  notes           String?
  organization_id Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project? @relation(fields: [project_id], references: [id])
  vendor  Vendor?  @relation(fields: [vendor_id], references: [id])
  creator User     @relation("ExpenseCreator", fields: [created_by], references: [id])

  @@map("expenses")
}

model Payroll {
  id              Int      @id @default(autoincrement())
  user_id         Int
  period          String
  basic_salary    Decimal
  bonuses         Decimal  @default(0)
  deductions      Decimal  @default(0)
  net_salary      Decimal
  status          String   @default("PENDING")
  paid_date       DateTime?
  organization_id Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee User @relation(fields: [user_id], references: [id])

  @@map("payroll")
}

// ═══════════════════════════════════════
// MARKETING MODULE
// ═══════════════════════════════════════

model Campaign {
  id              Int      @id @default(autoincrement())
  title           String
  description     String?
  type            String   @default("DIGITAL")
  platform        String   @default("ALL")
  status          String   @default("DRAFT")
  budget          Decimal?
  daily_budget    Decimal?
  spent           Decimal  @default(0)
  start_date      DateTime?
  end_date        DateTime?
  external_id          String?
  client_id            Int?
  project_id           Int?
  marketing_account_id Int?
  link_status          String   @default("UNLINKED")
  created_by           Int
  organization_id      Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  creator  User              @relation("CampaignCreator", fields: [created_by], references: [id])
  client   Client?           @relation("ClientCampaigns", fields: [client_id], references: [id])
  project  Project?          @relation("ProjectCampaigns", fields: [project_id], references: [id])
  account  MarketingAccount? @relation("AccountCampaigns", fields: [marketing_account_id], references: [id])
  leads    Lead[]
  metrics  CampaignMetric[]
  creatives Creative[]

  @@map("campaigns")
}

model CampaignMetric {
  id              Int      @id @default(autoincrement())
  campaign_id     Int
  date            DateTime @default(now())
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  conversions     Int      @default(0)
  spend           Decimal  @default(0)
  revenue         Decimal  @default(0)
  organization_id Int?
  createdAt       DateTime @default(now())

  campaign Campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)

  @@map("campaign_metrics")
}

model Creative {
  id          Int      @id @default(autoincrement())
  campaign_id Int
  file_url    String
  type        String   @default("IMAGE")
  ad_copy     String?
  created_at  DateTime @default(now())

  campaign Campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)

  @@map("creatives")
}

// ═══════════════════════════════════════
// PROCUREMENT MODULE
// ═══════════════════════════════════════

model Vendor {
  id              Int      @id @default(autoincrement())
  name            String
  contact_name    String?
  email           String?
  phone           String?
  address         String?
  category        String?
  rating          Int?     @default(0)
  status          String   @default("ACTIVE")
  created_by      Int
  organization_id Int?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  creator        User            @relation("VendorCreator", fields: [created_by], references: [id])
  rfqs           RFQ[]
  expenses       Expense[]
  stockPurchases StockPurchase[] @relation("PurchaseSupplier")

  @@map("vendors")
}

model RFQ {
  id              Int      @id @default(autoincrement())
  title           String
  description     String?
  vendor_id       Int
  project_id      Int?
  status          String   @default("DRAFT")
  deadline        DateTime?
  created_by      Int
  organization_id Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendor     Vendor      @relation(fields: [vendor_id], references: [id])
  creator    User        @relation("RFQCreator", fields: [created_by], references: [id])
  quotations Quotation[]

  @@map("rfqs")
}

model Quotation {
  id              Int      @id @default(autoincrement())
  rfq_id          Int
  amount          Decimal
  validity_days   Int      @default(30)
  status          String   @default("PENDING")
  notes           String?
  organization_id Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rfq           RFQ            @relation(fields: [rfq_id], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder?

  @@map("quotations")
}

model PurchaseOrder {
  id              Int      @id @default(autoincrement())
  quotation_id    Int      @unique
  po_number       String   @unique
  amount          Decimal
  status          String   @default("PENDING")
  delivery_date   DateTime?
  created_by      Int
  organization_id Int?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  quotation Quotation @relation(fields: [quotation_id], references: [id])
  creator   User      @relation("POCreator", fields: [created_by], references: [id])

  @@map("purchase_orders")
}

// ═══════════════════════════════════════
// SYSTEM: NOTIFICATIONS & ACTIVITY
// ═══════════════════════════════════════

model Notification {
  id              Int      @id @default(autoincrement())
  user_id         Int
  type            String   @default("INFO")
  title           String
  message         String
  link            String?
  read            Boolean  @default(false)
  organization_id Int?
  createdAt       DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ActivityLog {
  id              Int      @id @default(autoincrement())
  user_id         Int
  action          String
  module          String
  entity_id       Int?
  entity_type     String?
  description     String
  metadata        String?
  organization_id Int?
  lead_id         Int?
  deal_id         Int?
  client_id       Int?
  project_id      Int?
  task_id         Int?
  createdAt       DateTime @default(now())

  user    User     @relation("ActivityUser", fields: [user_id], references: [id])
  lead    Lead?    @relation(fields: [lead_id], references: [id])
  deal    Deal?    @relation(fields: [deal_id], references: [id])
  client  Client?  @relation(fields: [client_id], references: [id])
  project Project? @relation(fields: [project_id], references: [id])
  task    Task?    @relation(fields: [task_id], references: [id])

  @@map("activity_logs")
}

// ═══════════════════════════════════════
// POS & INVENTORY MODULE
// ═══════════════════════════════════════

model ProductCategory {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  products Product[]

  @@map("product_categories")
}

model Warehouse {
  id              Int      @id @default(autoincrement())
  name            String
  location        String?
  is_active       Boolean  @default(true)
  organization_id Int?
  createdAt       DateTime @default(now())

  inventory      Inventory[]
  posSales       PosSale[]
  stockPurchases StockPurchase[]

  @@map("warehouses")
}

model Product {
  id              Int      @id @default(autoincrement())
  name            String
  sku             String?  @unique
  barcode         String?  @unique
  price           Decimal  @default(0)
  cost            Decimal  @default(0)
  category_id     Int?
  is_active       Boolean  @default(true)
  organization_id Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category      ProductCategory?   @relation(fields: [category_id], references: [id])
  inventory     Inventory[]
  saleItems     PosSaleItem[]
  purchaseItems StockPurchaseItem[]
  cogsEntries   CogsEntry[]

  @@map("products")
}

model Inventory {
  id           Int      @id @default(autoincrement())
  product_id   Int
  warehouse_id Int
  quantity     Int      @default(0)
  min_quantity Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product   Product   @relation(fields: [product_id], references: [id])
  warehouse Warehouse @relation(fields: [warehouse_id], references: [id])

  @@unique([product_id, warehouse_id])
  @@map("inventory")
}

model PosSale {
  id              Int      @id @default(autoincrement())
  sale_number     String   @unique
  customer_id     Int?
  warehouse_id    Int?
  subtotal        Decimal  @default(0)
  discount        Decimal  @default(0)
  tax             Decimal  @default(0)
  total           Decimal  @default(0)
  payment_method  String   @default("CASH")
  payment_status  String   @default("PAID")
  status          String   @default("COMPLETED")
  notes           String?
  created_by      Int
  organization_id Int?
  createdAt       DateTime @default(now())

  customer  Client?       @relation("ClientPosSales", fields: [customer_id], references: [id])
  cashier   User          @relation("SaleCashier", fields: [created_by], references: [id])
  warehouse Warehouse?    @relation(fields: [warehouse_id], references: [id])
  items     PosSaleItem[]
  delivery  Delivery?

  @@map("pos_sales")
}

model PosSaleItem {
  id         Int     @id @default(autoincrement())
  sale_id    Int
  product_id Int
  quantity   Int
  price      Decimal
  cost       Decimal @default(0)
  discount   Decimal @default(0)

  sale    PosSale @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id])

  @@map("pos_sale_items")
}

model StockPurchase {
  id              Int       @id @default(autoincrement())
  purchase_number String    @unique
  supplier_id     Int?
  warehouse_id    Int?
  subtotal        Decimal   @default(0)
  tax             Decimal   @default(0)
  total           Decimal   @default(0)
  status          String    @default("PENDING")
  notes           String?
  created_by      Int
  organization_id Int?
  received_at     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  supplier  Vendor?             @relation("PurchaseSupplier", fields: [supplier_id], references: [id])
  warehouse Warehouse?          @relation(fields: [warehouse_id], references: [id])
  creator   User                @relation("PurchaseCreator", fields: [created_by], references: [id])
  items     StockPurchaseItem[]

  @@map("stock_purchases")
}

model StockPurchaseItem {
  id          Int     @id @default(autoincrement())
  purchase_id Int
  product_id  Int
  quantity    Int
  cost        Decimal

  purchase StockPurchase @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  product  Product       @relation(fields: [product_id], references: [id])

  @@map("stock_purchase_items")
}

model Delivery {
  id              Int       @id @default(autoincrement())
  delivery_number String    @unique
  sale_id         Int       @unique
  driver_id       Int?
  address         String?
  status          String    @default("PENDING")
  notes           String?
  assigned_at     DateTime?
  delivered_at    DateTime?
  organization_id Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sale   PosSale @relation(fields: [sale_id], references: [id])
  driver User?   @relation("DeliveryDriver", fields: [driver_id], references: [id])

  @@map("deliveries")
}

// ═══════════════════════════════════════
// PHASE 6: FINANCIAL DECISION ENGINE
// ═══════════════════════════════════════

model BusinessUnit {
  id              Int      @id @default(autoincrement())
  name            String
  code            String   @unique
  description     String?
  is_active       Boolean  @default(true)
  organization_id Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  fixedCosts        FixedCost[]
  allocationRules   CostAllocationRule[]
  allocationEntries CostAllocationEntry[]

  @@map("business_units")
}

model FixedCost {
  id               Int      @id @default(autoincrement())
  title            String
  category         String   @default("OVERHEAD")
  amount           Decimal
  business_unit_id Int?
  recurrence       String   @default("MONTHLY")
  period           String
  notes            String?
  organization_id  Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  businessUnit BusinessUnit? @relation(fields: [business_unit_id], references: [id])

  @@map("fixed_costs")
}

model CostAllocationRule {
  id               Int      @id @default(autoincrement())
  name             String
  source_category  String   @default("ALL")
  business_unit_id Int
  allocation_type  String   @default("PERCENTAGE")
  value            Decimal
  is_active        Boolean  @default(true)
  organization_id  Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  businessUnit BusinessUnit          @relation(fields: [business_unit_id], references: [id])
  entries      CostAllocationEntry[]

  @@map("cost_allocation_rules")
}

model CostAllocationEntry {
  id               Int      @id @default(autoincrement())
  rule_id          Int
  business_unit_id Int
  period           String
  allocated_amount Decimal
  notes            String?
  organization_id  Int?
  createdAt        DateTime @default(now())

  rule         CostAllocationRule @relation(fields: [rule_id], references: [id])
  businessUnit BusinessUnit       @relation(fields: [business_unit_id], references: [id])

  @@map("cost_allocation_entries")
}

model CogsEntry {
  id              Int      @id @default(autoincrement())
  period          String
  source          String   @default("STOCK_PURCHASE")
  source_id       Int?
  product_id      Int?
  description     String
  amount          Decimal
  notes           String?
  organization_id Int?
  createdAt       DateTime @default(now())

  product Product? @relation(fields: [product_id], references: [id])

  @@map("cogs_entries")
}

model CashFlowEntry {
  id              Int      @id @default(autoincrement())
  date            DateTime @default(now())
  type            String
  source          String   @default("MANUAL")
  source_id       Int?
  amount          Decimal
  description     String
  account         String   @default("BANK")
  period          String
  organization_id Int?
  createdAt       DateTime @default(now())

  @@map("cash_flow_entries")
}

// ═══════════════════════════════════════
// MARKETING OAUTH — AD ACCOUNTS
// ═══════════════════════════════════════

model MarketingAccount {
  id              Int       @id @default(autoincrement())
  user_id         Int
  platform        String
  account_id      String
  account_name    String
  access_token    String
  token_iv        String?   // AES-256-CBC IV for access_token encryption (hex)
  refresh_token   String?
  token_expiry    DateTime?
  status          String    @default("ACTIVE")
  last_synced_at  DateTime?
  organization_id Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user      User       @relation(fields: [user_id], references: [id])
  campaigns Campaign[] @relation("AccountCampaigns")

  @@unique([user_id, platform, account_id])
  @@map("marketing_accounts")
}
